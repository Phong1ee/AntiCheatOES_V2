{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: FastAPI Backend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}/backend",
            "args": [
                "main:app",
                "--reload",
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "console": "integratedTerminal"
        }
    ]
}